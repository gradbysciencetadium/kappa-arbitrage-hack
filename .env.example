# Copy this file to .env and fill in your values.

# ---- Required: Gemini (free tier, no card) ----
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Default Gemini model used for every role unless overridden below.
GEMINI_MODEL=gemini-2.5-flash
# Optional "strong" model for planner/critic/synthesis (defaults to GEMINI_MODEL).
GEMINI_STRONG_MODEL=gemini-2.5-flash
# How many times to wait-and-retry on rate-limit (429) / overload (503).
GEMINI_MAX_RETRIES=5

# ---- Per-stage model routing (all optional) ----
# Each pipeline stage names a ROLE. Point any role at a different provider/model
# without touching code. Providers: "gemini" or "openai-compatible".
# Example: route the parallel data workers to a free Groq Llama for speed/throughput.
# WORKER_PROVIDER=openai-compatible
# WORKER_MODEL=llama-3.3-70b-versatile

# ---- Optional: OpenAI-compatible provider (Groq / OpenRouter) ----
# Groq is free with a much higher rate limit than Gemini's free tier — useful for
# the many small worker calls AND to make Bara fast enough for Vercel's 300s limit.
# OPENAI_COMPAT_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_COMPAT_API_KEY=

# ---- FLock: "UK Sovereign AI" mode (hackathon: Best Use of FLock) ----
# Flip SOVEREIGN_AI=1 to route every stage through FLock's sovereign-aligned inference.
# Get a key + pick a model id from https://api.flock.io (its "list models" endpoint).
# SOVEREIGN_AI=1
# FLOCK_API_KEY=
# FLOCK_MODEL=Qwen3-30B

# ---- Supabase: persistence (conversations, briefs, reports, leads) ----
# Without these the app runs with an in-memory fallback (state lost on restart).
# Create a free project at https://supabase.com, run supabase/schema.sql, then paste:
#   Project URL  -> SUPABASE_URL
#   service_role key (Settings > API) -> SUPABASE_KEY
# SUPABASE_URL=
# SUPABASE_KEY=

# ---- Server ----
PORT=3000
